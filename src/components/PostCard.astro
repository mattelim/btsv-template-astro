---
interface Props {
	title: string;
	date: Date;
	description: string;
	slug: string;
	tags: string[];
}

const { title, date, description = '', slug, tags = [] } = Astro.props;
---

<article class="card">
	<h2><a href={`/${slug}`}>{title}</a></h2>
	<time datetime={date.toISOString()}>
		{date.toLocaleDateString('en-US', {
			year: 'numeric',
			month: 'long',
			day: 'numeric'
		})}
	</time>
	{description && <p>{description}</p>}
	{tags.length > 0 && (
		<div class="tags">
			{tags.map((tag) => (
				<a href={`/tags/${tag}`}>{tag}</a>
			))}
		</div>
	)}
</article>
