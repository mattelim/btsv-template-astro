---
interface Props {
	src: string;
	alt: string;
	caption: string;
}

const { src, alt, caption = '' } = Astro.props;
---

<figure>
	<img src={src} alt={alt} loading="lazy" />
	{caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
	figure {
		margin: 1.5rem 0;
		text-align: center;
	}

	img {
		max-width: 100%;
		height: auto;
		border-radius: 6px;
	}

	figcaption {
		font-size: 0.8125rem;
		color: var(--color-text-muted);
		margin-top: 0.5rem;
	}
</style>
